// Stages are:
// 0 = Update neighbourhood forces
// 1 = Update softcollision forces
// 2 = Update velocity using forces
// 3 = Update position using forces
// 4 = Handle hard collision (In case soft collision have failed) (Boundary + Interiors)
// 5 = Update transform

#include "../math_common.glsl"
